{
	"name": "@mscharley/node-presets",
	"version": "1.0.0",
	"private": true,
	"description": "Metaproject for this repo",
	"type": "module",
	"scripts": {
		"cs-version": "turbo build && changeset version",
		"cs-release": "changeset publish"
	},
	"devDependencies": {
		"@changesets/cli": "2.30.0",
		"@mscharley/eslint-config": "workspace:*",
